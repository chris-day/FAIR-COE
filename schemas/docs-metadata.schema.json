{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "docs-metadata",
  "type": "object",
  "required": ["slug", "section", "docs_root", "nav"],
  "properties": {
    "slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "section": {"type": "string", "minLength": 1},
    "docs_root": {"type": "string", "minLength": 1},
    "nav": {"type": "array"},
    "redirects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": {"type": "string"},
          "to": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "mkdocs_requests": {"type": "object", "additionalProperties": true}
  },
  "additionalProperties": true
}